# Local map tiles
NEXT_PUBLIC_ENABLE_QA_LAYERS=false
NEXT_PUBLIC_TILE_URL_PRE=http://localhost:8080/tiles/vn_provinces_pre_2025
NEXT_PUBLIC_TILE_URL_POST=http://localhost:8080/tiles/vn_provinces_post_2025
NEXT_PUBLIC_TILE_URL_ISLANDS=http://localhost:8080/tiles/vn_offshore_islands
# Reef-shallows fill (reef minus emergent land — islands punched out as holes). The turquoise fill
# uses this; the territorial outline + label use _ISLANDS (full extent). Falls back to _ISLANDS if unset.
NEXT_PUBLIC_TILE_URL_ISLANDS_REEF=http://localhost:8080/tiles/vn_offshore_reefs
NEXT_PUBLIC_TILE_URL_PRE_DISTRICTS_CANDIDATE=http://localhost:8080/tiles/vn_districts_pre_2025_candidate
NEXT_PUBLIC_TILE_URL_PRE_DISTRICTS_CANDIDATE_LABELS=http://localhost:8080/tiles/vn_districts_pre_2025_candidate_labels
NEXT_PUBLIC_TILE_URL_POST_WARDS_CANDIDATE=http://localhost:8080/tiles/vn_wards_post_2025_candidate
NEXT_PUBLIC_TILE_URL_POST_WARDS_CANDIDATE_LABELS=http://localhost:8080/tiles/vn_wards_post_2025_candidate_labels
# Self-built OMT basemap (Track A-SB). Served from public/omt-basemap-style.json; the style
# references region-omt/world-omt PMTiles + sprite + fonts on R2 (tiles.viettrace.org/basemap).
# Regenerate with scripts/generate-omt-basemap-style.mjs (OMT_LOCAL=1 for the local :8600 preview).
# Emergency fallback: https://basemaps.cartocdn.com/gl/positron-gl-style/style.json
NEXT_PUBLIC_MAP_STYLE=/omt-basemap-style.json
NEXT_PUBLIC_TILE_CACHE_BUSTER=

# ── Production (ADR-0016): ALL map tiles are static PMTiles on ONE domain, tiles.viettrace.org
# (Cloudflare R2 bucket `viettrace-tiles`; paths /basemap, /boundaries, /nested). Martin is retired
# for serving. PMTiles URLs take priority over the legacy Martin NEXT_PUBLIC_TILE_URL_* above.
# Leave NEXT_PUBLIC_ENABLE_QA_LAYERS unset or false in production.
#
# Provinces L4 + offshore (islands outline + reef-shallows fill):
# NEXT_PUBLIC_PMTILES_URL_PRE=https://tiles.viettrace.org/boundaries/vn_provinces_pre_2025.pmtiles
# NEXT_PUBLIC_PMTILES_URL_POST=https://tiles.viettrace.org/boundaries/vn_provinces_post_2025.pmtiles
# NEXT_PUBLIC_PMTILES_URL_ISLANDS=https://tiles.viettrace.org/boundaries/vn_offshore_islands.pmtiles
# NEXT_PUBLIC_PMTILES_URL_ISLANDS_REEF=https://tiles.viettrace.org/boundaries/vn_offshore_reefs.pmtiles
#
# Nested boundaries (districts pre-2025, wards post-2025) — polygons + label points.
# Visible to all users when set; minzoom keeps them hidden at low zoom.
# NEXT_PUBLIC_PMTILES_URL_PRE_DISTRICTS_CANDIDATE=https://tiles.viettrace.org/nested/vn_districts_pre_2025_candidate.pmtiles
# NEXT_PUBLIC_PMTILES_URL_POST_WARDS_CANDIDATE=https://tiles.viettrace.org/nested/vn_wards_post_2025_candidate.pmtiles
# NEXT_PUBLIC_PMTILES_URL_PRE_DISTRICTS_CANDIDATE_LABELS=https://tiles.viettrace.org/nested/vn_districts_pre_2025_candidate_labels.pmtiles
# NEXT_PUBLIC_PMTILES_URL_POST_WARDS_CANDIDATE_LABELS=https://tiles.viettrace.org/nested/vn_wards_post_2025_candidate_labels.pmtiles
#
# NEXT_PUBLIC_TILE_CACHE_BUSTER=20260621
# NEXT_PUBLIC_SITE_URL=https://viettrace.org
#
# Legacy Martin endpoints (pre-ADR-0016, retired for serving — keep only as a manual fallback):
# NEXT_PUBLIC_TILE_URL_PRE=https://tiles.viettrace.org/tiles/vn_provinces_pre_2025
# NEXT_PUBLIC_TILE_URL_POST=https://tiles.viettrace.org/tiles/vn_provinces_post_2025
# NEXT_PUBLIC_TILE_URL_ISLANDS=https://tiles.viettrace.org/tiles/vn_offshore_islands

# Sentry configs
NEXT_PUBLIC_SENTRY_ENABLED=false
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
